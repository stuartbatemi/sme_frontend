# React environment variables for production
# Copy this file to .env and fill in your values
# In Vercel: add these under Project Settings → Environment Variables

# URL of your deployed Node.js backend (Railway URL)
VITE_API_URL=https://your-node-backend.railway.app

# URL of your deployed FastAPI model server (Railway URL)
VITE_FASTAPI_URL=https://your-fastapi-server.railway.app
